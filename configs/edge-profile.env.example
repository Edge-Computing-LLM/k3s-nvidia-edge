# Production edge profile for Ubuntu/Xubuntu 22+ with k3s and NVIDIA GPU.
# This file is documentation for the defaults currently encoded in the CLI.

K3S_CHANNEL=stable
K3S_EXEC="server --write-kubeconfig-mode 644"
GPU_OPERATOR_VERSION=v26.3.3
CUDA_TEST_IMAGE=nvidia/cuda:12.8.0-base-ubuntu24.04
MIN_CUDA_VERSION=12.8
REQUIRE_HOST_CUDA=true
GPU_OPERATOR_DRIVER_ENABLED=false
GPU_OPERATOR_TOOLKIT_ENABLED=true
GPU_OPERATOR_GFD_ENABLED=false

# k3s containerd paths used by the NVIDIA GPU Operator toolkit operand.
CONTAINERD_CONFIG=/var/lib/rancher/k3s/agent/etc/containerd/config.toml
CONTAINERD_SOCKET=/run/k3s/containerd/containerd.sock
RUNTIME_CONFIG_SOURCE=file=/var/lib/rancher/k3s/agent/etc/containerd/config.toml
